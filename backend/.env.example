# Port number
PORT=9000

# Postgres URL
DATABASE_URL=""

# JWT
# JWT secret key
JWT_SECRET=thisisasamplesecret
# Number of minutes after which an access token expires
JWT_ACCESS_EXPIRATION_MINUTES=30
# Number of days after which a refresh token expires
JWT_REFRESH_EXPIRATION_DAYS=30
# Number of minutes after which a reset password token expires
JWT_RESET_PASSWORD_EXPIRATION_MINUTES=10
# Number of minutes after which a verify email token expires
JWT_VERIFY_EMAIL_EXPIRATION_MINUTES=10

# LLM Provider Configuration
# Fallback behavior: keep AI endpoints working with deterministic mock output when external AI infra is not configured.
# Set to 'false' only when you fully configure live AI provider + infra env.
AI_FALLBACK_MODE=true

# Anthropic Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Google Gemini Configuration
GEMINI_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-3-flash-preview
# Gemini Image Generation Model (multi-modal models: gemini-2.5-flash-image, gemini-3-pro-image-preview)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Payment Gateway Configuration

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
FRONTEND_DOMAIN=
BACKEND_DOMAIN=
# Google OAuth (required for Google login)
GOOGLE_OAUTH_CLIENT_ID=500221018476-3qikeg5pvtgpg2fj8r52ek0mqf9r5t3k.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://taskflowaiassistant.netlify.app/login
# Email Configuration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_FROM="UPTIQ <no-reply@uptiq.ai>"

# Resend API Key (Optional fallback)
RESEND_API_KEY=re_123456789

# Storage / Infra Provider
# Example values depend on your integrations setup. If omitted, backend falls back to mock file URLs.
INFRA_PROVIDER=
