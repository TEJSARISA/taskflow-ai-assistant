# Backend API Base URL
VITE_API_BASE_URL=http://localhost:9000

# Agent SDK Base URL (for Claude Agent SDK integration)
VITE_AGENT_BASE_URL=http://localhost:3000

# Mock Data Mode (set to 'false' to use live API calls instead of mock data)
VITE_USE_MOCK_DATA=true

# Google OAuth fallback in mock mode. Keep 'true' for demo login when no live backend URL is configured.
VITE_GOOGLE_AUTH_MOCK_FALLBACK=true

# Optional: set to 'true' to use live backend chat while keeping other features in mock mode
VITE_FORCE_LIVE_CHAT=false
